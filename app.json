{
  "expo": {
    "name": "ReferralFit",
    "slug": "referralfit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-fit-point.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mattbrown.referralfit",
      "buildNumber": "6",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon-fit-point.png",
      "bundler": "metro"
    },
    "scheme": "referralfit",
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "931063d5-1135-428d-adb9-572c7fe0885e"
      }
    },
    "owner": "mattbrown0406"
  }
}
