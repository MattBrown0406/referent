{
  "expo": {
    "name": "ReferralFit",
    "slug": "referralfit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-bridge.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mattbrown.referralfit",
      "buildNumber": "7",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mattbrown.referralfit",
      "adaptiveIcon": {
        "backgroundColor": "#FCF9F2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "referralfit",
    "plugins": [
      "expo-font",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow ReferralFit to add case participants to your contacts when you choose Add to Contacts."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow ReferralFit to add case appointments to your calendar when you choose Add to Calendar.",
          "remindersPermission": "Allow ReferralFit to add reminders when you explicitly request them."
        }
      ],
      "expo-document-picker",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "931063d5-1135-428d-adb9-572c7fe0885e"
      }
    },
    "owner": "mattbrown0406"
  }
}
